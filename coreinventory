                  <div className="col-span-2">
                    <label className="block text-sm font-bold text-gray-700 mb-1">Initial Stock (Optional)</label>
                    <input name="initialStock" type="number" defaultValue={0} className="w-full px-4 py-2 border rounded-xl" />
                  </div>
                )}
              </div>
              <div className="pt-4">
                <button type="submit" className="w-full bg-blue-600 text-white py-3 rounded-xl font-bold hover:bg-blue-700 transition">
                  {editingProduct ? 'Update Product' : 'Save Product'}
                </button>
              </div>
            </form>
          </div>
        </div>
      )}
    </div>
  );
}

// --- Operations View (Receipts, Deliveries, Transfers, Adjustments) ---
function OperationsView({ type, operations, products, warehouses }) {
  const [showForm, setShowForm] = useState(false);
  const [selectedOp, setSelectedOp] = useState(null);

  const filteredOps = useMemo(() => operations.filter(o => o.type === type), [operations, type]);

  const validateOperation = async (op) => {
    if (op.status === STATUS.DONE) return;

    try {
      await runTransaction(db, async (transaction) => {
        // 1. Process each item in the operation
        for (const item of op.items) {
          const productRef = doc(db, 'artifacts', appId, 'public', 'data', 'products', item.productId);
          const pDoc = await transaction.get(productRef);
          if (!pDoc.exists()) continue;

          const currentStock = Number(pDoc.data().currentStock);
          const itemQty = Number(item.qty);
          let newStock = currentStock;

          if (type === OPERATION_TYPES.RECEIPT) newStock += itemQty;
          if (type === OPERATION_TYPES.DELIVERY) newStock -= itemQty;
          if (type === OPERATION_TYPES.ADJUSTMENT) newStock = itemQty; // Adjust directly to counted value
          // Note: Internal transfers would require location-based stock if implemented, 
          // but for this modular logic, we treat it as an internal move affecting global stock only if cross-entity.
          // For simplicity, receipts/deliveries affect global count.

          transaction.update(productRef, { currentStock: newStock });

          // 2. Log to history
          const historyRef = doc(collection(db, 'artifacts', appId, 'public', 'data', 'moveHistory'));
          transaction.set(historyRef, {
            productId: item.productId,
            operationType: type,
            qty: itemQty,
            prevStock: currentStock,
            newStock: newStock,
            ref: op.reference || op.id,
            timestamp: serverTimestamp()
          });
        }

        // 3. Mark operation as DONE
        const opRef = doc(db, 'artifacts', appId, 'public', 'data', 'operations', op.id);
        transaction.update(opRef, { status: STATUS.DONE, validatedAt: serverTimestamp() });
      });
      setSelectedOp(null);
    } catch (err) {
      console.error("Validation failed:", err);
    }
  };

  return (
    <div className="space-y-6">
      <div className="flex justify-between items-center">
        <h3 className="text-lg font-semibold text-gray-500">Manage {type}s</h3>
        <button 
          onClick={() => setShowForm(true)}
          className="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 hover:bg-blue-700 shadow-sm"
        >
          <Plus size={18} /> Create New {type.charAt(0).toUpperCase() + type.slice(1)}
        </button>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {filteredOps.map(op => (
          <div key={op.id} className="bg-white rounded-2xl border shadow-sm p-5 hover:border-blue-200 transition">
            <div className="flex justify-between items-start mb-4">
              <div>
                <span className={`px-2 py-1 rounded text-[10px] font-black uppercase tracking-widest ${
                  op.status === STATUS.DONE ? 'bg-green-100 text-green-700' : 'bg-blue-100 text-blue-700'
                }`}>
                  {op.status}
                </span>
                <p className="font-bold text-gray-900 mt-2">{op.reference || `REF-${op.id.slice(0,5)}`}</p>
                <p className="text-xs text-gray-500">Created: {op.createdAt?.seconds ? new Date(op.createdAt.seconds * 1000).toLocaleDateString() : 'N/A'}</p>
              </div>
              <div className="flex gap-1">
                {op.status !== STATUS.DONE && (
                  <button onClick={() => validateOperation(op)} className="p-2 text-green-600 hover:bg-green-50 rounded-lg">
                    <CheckCircle2 size={20} />
                  </button>
                )}
                <button onClick={() => setSelectedOp(op)} className="p-2 text-gray-400 hover:bg-gray-50 rounded-lg">
                  <ChevronRight size={20} />
                </button>
              </div>
            </div>
            <div className="space-y-2">
              <div className="flex items-center gap-2 text-sm text-gray-600">
                <Warehouse size={14} />
                <span>{op.warehouseId ? warehouses.find(w => w.id === op.warehouseId)?.name : 'N/A'}</span>
              </div>
              <div className="text-xs font-medium text-gray-400">
                {op.items?.length || 0} Products Included
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Operation Form Modal */}
      {showForm && (
        <OperationForm 
          type={type} 
          products={products} 
          warehouses={warehouses} 
          onClose={() => setShowForm(false)} 
          appId={appId} 
        />
      )}

      {/* Detail View Modal */}
      {selectedOp && (
        <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
          <div className="bg-white rounded-2xl w-full max-w-2xl shadow-2xl">
            <div className="p-6 border-b flex justify-between items-center">
              <div>
                <h3 className="text-xl font-bold">Operation Details</h3>
                <p className="text-sm text-gray-500">{selectedOp.reference}</p>
              </div>
              <button onClick={() => setSelectedOp(null)} className="text-gray-400 hover:text-gray-600"><XCircle /></button>
            </div>
            <div className="p-6 space-y-6">
              <div className="grid grid-cols-2 gap-4 text-sm">
                <div>
                  <p className="text-gray-400 font-bold uppercase text-[10px]">Source/Dest</p>
                  <p className="font-medium">{selectedOp.source || 'Warehouse'}</p>
                </div>
                <div>
                  <p className="text-gray-400 font-bold uppercase text-[10px]">Status</p>
                  <p className={`font-bold ${selectedOp.status === STATUS.DONE ? 'text-green-600' : 'text-blue-600'}`}>{selectedOp.status}</p>
                </div>
              </div>

              <div className="border rounded-xl overflow-hidden">
                <table className="w-full text-left">
                  <thead className="bg-gray-50 text-[10px] font-bold text-gray-500 uppercase">
                    <tr>
                      <th className="px-4 py-2">Product</th>
                      <th className="px-4 py-2">Quantity</th>
                    </tr>
                  </thead>
                  <tbody className="divide-y text-sm">
                    {selectedOp.items.map((item, idx) => (
                      <tr key={idx}>
                        <td className="px-4 py-3">{products.find(p => p.id === item.productId)?.name || 'Unknown'}</td>
                        <td className="px-4 py-3 font-bold">{item.qty}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
            {selectedOp.status !== STATUS.DONE && (
              <div className="p-6 bg-gray-50 rounded-b-2xl border-t">
                <button 
                  onClick={() => validateOperation(selectedOp)}
                  className="w-full bg-green-600 text-white py-3 rounded-xl font-bold hover:bg-green-700 transition flex items-center justify-center gap-2 shadow-lg"
                >
                  <CheckCircle2 size={20} /> Validate & Update Stock
                </button>
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  );
}

// --- Specific Operation Form ---
function OperationForm({ type, products, warehouses, onClose, appId }) {
  const [items, setItems] = useState([{ productId: '', qty: 0 }]);
  const [warehouseId, setWarehouseId] = useState(warehouses[0]?.id || '');
  const [loading, setLoading] = useState(false);

  const addItem = () => setItems([...items, { productId: '', qty: 0 }]);
  const removeItem = (idx) => setItems(items.filter((_, i) => i !== idx));
  const updateItem = (idx, field, value) => {
    const newItems = [...items];
    newItems[idx][field] = value;
    setItems(newItems);
  };

  const handleSubmit = async (e) => {
    e.preventDefault();
    setLoading(true);
    const formData = new FormData(e.target);
    const opData = {
      type,
      warehouseId,
      source: formData.get('source'),
      reference: formData.get('reference') || `${type.toUpperCase()}-${Date.now().toString().slice(-6)}`,
      items,
      status: STATUS.DRAFT,
      createdAt: serverTimestamp()
    };

    try {
      await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'operations'), opData);
      onClose();
    } catch (err) {
      console.error(err);
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
      <div className="bg-white rounded-2xl w-full max-w-2xl shadow-2xl animate-in slide-in-from-bottom-4">
        <div className="p-6 border-b flex justify-between items-center">
          <h3 className="text-xl font-bold capitalize">New {type}</h3>
          <button onClick={onClose} className="text-gray-400 hover:text-gray-600"><XCircle /></button>
        </div>
        <form onSubmit={handleSubmit} className="p-6 space-y-6">
          <div className="grid grid-cols-2 gap-4">
            <div>
              <label className="block text-sm font-bold text-gray-700 mb-1">Warehouse</label>
              <select 
                value={warehouseId} 
                onChange={(e) => setWarehouseId(e.target.value)}
                className="w-full px-4 py-2 border rounded-xl"
              >
                {warehouses.map(w => <option key={w.id} value={w.id}>{w.name}</option>)}
              </select>
            </div>
            <div>
              <label className="block text-sm font-bold text-gray-700 mb-1">
                {type === OPERATION_TYPES.RECEIPT ? 'Supplier' : type === OPERATION_TYPES.DELIVERY ? 'Customer' : 'Reference'}
              </label>
              <input name="source" placeholder="Name or Location" className="w-full px-4 py-2 border rounded-xl" />
            </div>
          </div>

          <div className="space-y-3">
            <div className="flex justify-between items-center">
              <label className="text-sm font-bold text-gray-700">Products & Quantities</label>
              <button type="button" onClick={addItem} className="text-blue-600 text-xs font-bold hover:underline">+ Add Product</button>
            </div>
            <div className="max-h-64 overflow-y-auto space-y-3 pr-2">
              {items.map((item, idx) => (
                <div key={idx} className="flex gap-2 items-center">
                  <select 
                    value={item.productId} 
                    onChange={(e) => updateItem(idx, 'productId', e.target.value)}
                    required
                    className="flex-1 px-4 py-2 border rounded-xl"
                  >
                    <option value="">Select Product...</option>
                    {products.map(p => <option key={p.id} value={p.id}>{p.name} (SKU: {p.sku})</option>)}
                  </select>
                  <input 
                    type="number" 
                    placeholder="Qty" 
                    value={item.qty}
                    onChange={(e) => updateItem(idx, 'qty', e.target.value)}
                    className="w-24 px-4 py-2 border rounded-xl"
                    required
                  />
                  <button type="button" onClick={() => removeItem(idx)} className="text-red-500 p-2"><XCircle size={18} /></button>
                </div>
              ))}
            </div>
          </div>

          <div className="pt-4 border-t">
            <button 
              disabled={loading}
              type="submit" 
              className="w-full bg-blue-600 text-white py-3 rounded-xl font-bold hover:bg-blue-700 transition shadow-lg disabled:opacity-50"
            >
              {loading ? 'Creating...' : `Create ${type}`}
            </button>
          </div>
        </form>
      </div>
    </div>
  );
}

// --- History View ---
function HistoryView({ history, products }) {
  const sortedHistory = useMemo(() => {
    return [...history].sort((a, b) => b.timestamp?.seconds - a.timestamp?.seconds);
  }, [history]);

  return (
    <div className="bg-white rounded-2xl border shadow-sm overflow-hidden">
      <table className="w-full text-left">
        <thead className="bg-gray-50 border-b">
          <tr>
            <th className="px-6 py-4 text-xs font-bold text-gray-500 uppercase">Product</th>
            <th className="px-6 py-4 text-xs font-bold text-gray-500 uppercase">Type</th>
            <th className="px-6 py-4 text-xs font-bold text-gray-500 uppercase">Change</th>
            <th className="px-6 py-4 text-xs font-bold text-gray-500 uppercase">New Balance</th>
            <th className="px-6 py-4 text-xs font-bold text-gray-500 uppercase">Reference</th>
            <th className="px-6 py-4 text-xs font-bold text-gray-500 uppercase">Date</th>
          </tr>
        </thead>
        <tbody className="divide-y text-sm">
          {sortedHistory.map(h => (
            <tr key={h.id} className="hover:bg-gray-50">
              <td className="px-6 py-4 font-medium">{products.find(p => p.id === h.productId)?.name || 'Deleted Product'}</td>
              <td className="px-6 py-4">
                <span className={`capitalize font-bold px-2 py-0.5 rounded text-[10px] ${
                  h.operationType === 'receipt' ? 'bg-green-100 text-green-700' : 
                  h.operationType === 'delivery' ? 'bg-purple-100 text-purple-700' : 'bg-blue-100 text-blue-700'
                }`}>
                  {h.operationType}
                </span>
              </td>
              <td className={`px-6 py-4 font-bold ${h.operationType === 'receipt' ? 'text-green-600' : 'text-red-600'}`}>
                {h.operationType === 'receipt' ? `+${h.qty}` : `-${h.qty}`}
              </td>
              <td className="px-6 py-4 font-black text-gray-700">{h.newStock}</td>
              <td className="px-6 py-4 text-gray-500">{h.ref}</td>
              <td className="px-6 py-4 text-gray-400">
                {h.timestamp?.seconds ? new Date(h.timestamp.seconds * 1000).toLocaleString() : 'Just now'}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      {history.length === 0 && (
        <div className="p-12 text-center text-gray-500">No transactions recorded yet.</div>
      )}
    </div>
  );
}

